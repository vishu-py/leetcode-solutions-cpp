#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    int shipWithinDays(vector<int>& weights, int days) {
        int n=weights.size();
        int l=*max_element(weights.begin(), weights.end());
        long long h=0;
        for(int w: weights){
            h+=w;
        }
        int ans=h;

        while(l<=h){
            int mid=l+(h-l)/2;
            int day=1;
            long long sum=0;
            
            for(int i=0; i<n; i++){
                if(sum+weights[i]<=mid){
                    sum+=weights[i];
                }
                else{
                    day++;
                    sum=weights[i];
                }
            }
            if(day<=days){
                h=mid-1;
                ans=mid;
            }
            else{
                l=mid+1;
            }
        }
        return ans;
    }
};